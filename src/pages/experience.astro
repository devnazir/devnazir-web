---
import Briefcase from "../icons/Briefcase.astro";
import Layout from "../layouts/Layout.astro";
import { EXPERIENCES } from "../constants";
---

<Layout title="devnazir - Works Experiences">
  <h1 class="md:text-3xl text-xl">Experience</h1>
  <div class="mt-2 flex justify-between">
    <span class="block md:text-sm text-xs">
      List of my work experiences, from the most recent to the oldest.
    </span>
  </div>

  <div class="mt-14 flex flex-col md:w-1/2">
    {
      EXPERIENCES.map((experience) => {
        return (
          <div class="flex gap-4">
            <div class="flex flex-col items-center shrink-0">
              <div class="shrink-0">
                <Briefcase />
              </div>
              <span class="w-[2px] bg-gray-300 h-full" />
            </div>
            <div class="pb-8 -translate-y-1">
              <span class="block text-xl">{experience.title}</span>
              <span class="text-sm block">{experience.company}</span>
              <div class="flex gap-2 italic text-gray-500 text-sm ">
                <span class="block">{experience.start}</span>
                <span class="block">-</span>
                <span class="block">{experience.end}</span>
              </div>
              <p class="whitespace-pre-line text-sm">
                {experience.description}
              </p>

              <span class="mt-4 inline-block text-sm ">
                <strong>Skills: </strong>{" "}
                <span class="font-normal">{experience.skills.join(", ")}</span>
              </span>
            </div>
          </div>
        );
      })
    }
  </div>
</Layout>
