---
import Layout from "../layouts/Layout.astro";
import { SKILLS } from "../constants";
import SkillCard from "../components/SkillCard.astro";
---

<Layout title="devnazir - Skills">
  <h1 class="md:text-3xl text-xl">Skills</h1>
  <div class="mt-2 flex justify-between">
    <span class="block md:text-sm text-xs">
      List of skills I have acquired over the years, and never stop learning.
    </span>
  </div>

  <div
    class="grid lg:grid-cols-4 md:grid-cols-3 sm:grid-cols-2 grid-cols-1 mt-4 gap-4"
  >
    {
      SKILLS.map((skill) => {
        return <SkillCard {...skill} />;
      })
    }
  </div>
</Layout>
