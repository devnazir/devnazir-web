---
const MENUS = [
  {
    name: "Projects",
    path: "/projects",
  },
  {
    name: "Skills",
    path: "/skills",
  },
  {
    name: "Work Experience",
    path: "/experience",
  },
];

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1);
---

<nav class="w-full px-8 py-6 sticky top-0 bg-[rgba(255,255,255,0.8)] z-50 backdrop-blur-lg flex justify-between items-center">
  
  <a class="text-2xl font-bold" href="/">
    <span class="">{"<dev"}</span>
    <span class="text-purple-500">nazir</span>
    <span class="">{" />"}</span>
  </a>

  <ul class="flex gap-12">
    {
      MENUS.map((menu) => (
        <li class="inline-block text-sm">
          <a
            class:list={[
              "text-gray-500 font-medium hover:text-purple-500",
              {
                "text-purple-500": currentPath === menu.path.slice(1),
              },
            ]}
            href={menu.path}
          >
            {menu.name}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
