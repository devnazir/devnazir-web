---
import LinkedinIcon from "../icons/Linkedin.astro";
import GithubIcon from "../icons/Github.astro";
import YoutubeIcon from "../icons/Youtube.astro";
import TwitterIcon from "../icons/Twitter.astro";

const LINKS = [
  {
    url: "https://www.linkedin.com/in/nazirbahrululum/",
    name: "linkedin",
    Icon: LinkedinIcon,
  },
  {
    url: "https://github.com/devnazir",
    name: "github",
    Icon: GithubIcon,
  },
  {
    url: "https://www.youtube.com/@devnazir",
    name: "youtube",
    Icon: YoutubeIcon,
  },
  {
    url: "https://twitter.com/nazir_ulum",
    name: "twitter",
    Icon: TwitterIcon,
  },
];
---

<footer
  class="p-6 rounded-lg bg-gray-50 mt-4 mx-auto text-center flex justify-center"
>
  <ul class="flex gap-4">
    {
      LINKS.map((link) => {
        const Icon = link?.Icon || (() => null);

        return (
          <a
            target="_blank"
            rel="noreferrer"
            class="flex gap-2 items-center text-gray-500 hover:text-gray-900"
            href={link.url}
          >
            <span>{<Icon />}</span>
            <span class="hidden sm:block">{link.name}</span>
          </a>
        );
      })
    }
  </ul>
</footer>
